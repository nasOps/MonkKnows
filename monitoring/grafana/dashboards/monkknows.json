{
  "id": null,
  "uid": "monkknows-telemetry",
  "title": "MonkKnows User Telemetry",
  "tags": ["monkknows"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 5,
      "title": "Total Registered Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "app_users_total{job=\"monkknows\"}",
          "legendFormat": "Users"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "title": "Total Searches",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "app_searches_total{job=\"monkknows\"}",
          "legendFormat": "Searches"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 7,
      "title": "Zero-Result Searches",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "app_search_zero_results_total{job=\"monkknows\"}",
          "legendFormat": "No results"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 1,
      "title": "Request Rate per Endpoint (app routes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"monkknows\",path=~\"/|/api/.*|/health|/hello|/login|/register|/weather|/logout|/metrics\"}[5m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "title": "Login Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"monkknows\",path=\"/api/login\",code=\"200\"}[5m]))",
          "legendFormat": "Successful logins/s"
        },
        {
          "expr": "sum(rate(http_server_requests_total{job=\"monkknows\",path=\"/api/login\",code=\"422\"}[5m]))",
          "legendFormat": "Failed logins/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 8,
      "title": "Search Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(app_searches_total{job=\"monkknows\"}[5m])",
          "legendFormat": "Searches/s"
        },
        {
          "expr": "rate(app_search_zero_results_total{job=\"monkknows\"}[5m])",
          "legendFormat": "Zero results/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate: 4xx vs 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"monkknows\",code=~\"4..\"}[5m]))",
          "legendFormat": "4xx (minor)"
        },
        {
          "expr": "sum(rate(http_server_requests_total{job=\"monkknows\",code=~\"5..\"}[5m]))",
          "legendFormat": "5xx (breaking)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 4,
      "title": "Request Latency (p50, p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"monkknows\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"monkknows\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 9,
      "title": "Bot/Scanner Traffic (non-app routes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"monkknows\",path!~\"/|/api/.*|/health|/hello|/login|/register|/weather|/logout|/metrics\"}[5m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    }
  ]
}
